---
const asset = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, "")}/${path}`;

interface Props {
  profile: any;
  hero: any;
  nav: any;
  switchPath: string;
  switchLabel: string;
}

const { profile, hero, nav, switchPath, switchLabel } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const localPath = (path: string) => `${base}${path === "/" ? "/" : path}`;
const availabilityWords = hero.availability.split(" ");
const availabilityLead = availabilityWords.slice(0, 4).join(" ");
const availabilityRest = availabilityWords.slice(4).join(" ");
---

<section class="relative overflow-hidden pb-16 pt-4 sm:pb-24 sm:pt-6">
  <div class="container">
    <header class="flex justify-end py-3 text-sm text-slate-200">
      <nav class="flex flex-wrap items-center gap-4 rounded-full border border-white/10 bg-slate-950/55 px-5 py-2 shadow-lg shadow-black/20 backdrop-blur-md" aria-label="Primary navigation">
        <a class="hover:text-cyan-300" href="#services">{nav.services}</a>
        <a class="hover:text-cyan-300" href="#projects">{nav.projects}</a>
        <a class="hover:text-cyan-300" href="#contact">{nav.contact}</a>
        <a class="rounded-full border border-cyan-300/30 px-2 py-0.5 font-bold text-cyan-200 hover:border-cyan-200 hover:text-white" href={localPath(switchPath)}>{switchLabel}</a>
      </nav>
    </header>

    <div class="pt-4 lg:pt-6">
      <div class="section-frame overflow-hidden rounded-xl border border-cyan-300/20 bg-[#070b10] shadow-2xl shadow-cyan-950/30">
        <div class="relative overflow-hidden px-5 py-8 sm:px-8 lg:px-14 lg:py-12">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_52%_32%,rgba(34,211,238,0.16),transparent_30%),linear-gradient(90deg,rgba(8,13,22,0.98),rgba(8,13,22,0.78)_50%,rgba(8,13,22,0.98))]"></div>
          <div class="relative z-10 grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(280px,340px)] lg:items-center xl:grid-cols-[minmax(380px,1fr)_minmax(300px,340px)_minmax(300px,0.9fr)] xl:gap-10">
            <div class="min-w-0">
              <p class="eyebrow">{hero.eyebrow}</p>
              <h1 class="max-w-[8.4em] text-5xl font-black leading-[0.95] tracking-normal text-white sm:text-6xl xl:text-[4.6rem]">
                {profile.name}
              </h1>
              <p class="mt-5 max-w-md text-2xl font-semibold leading-tight text-slate-100">
                {hero.role}
              </p>
              <p class="mt-4 max-w-md text-base leading-7 text-slate-300">
                {hero.short}
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <a class="button button-primary" href={profile.links.email} aria-label={`${hero.primaryCta} - ${profile.name}`}>{hero.primaryCta}</a>
                <a class="button button-secondary h-12 w-12 p-0" href={profile.links.github} target="_blank" rel="noreferrer" aria-label="GitHub" title="GitHub">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
                    <path d="M12 .5A11.5 11.5 0 0 0 8.36 22.9c.58.1.79-.25.79-.56v-2.1c-3.22.7-3.9-1.38-3.9-1.38-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.72 1.27 3.38.97.1-.75.4-1.27.74-1.56-2.57-.29-5.27-1.28-5.27-5.72 0-1.26.45-2.3 1.2-3.1-.12-.3-.52-1.48.11-3.07 0 0 .98-.31 3.17 1.18A11 11 0 0 1 12 5.97c.98 0 1.96.13 2.88.39 2.2-1.49 3.16-1.18 3.16-1.18.64 1.59.24 2.78.12 3.07.75.8 1.2 1.84 1.2 3.1 0 4.45-2.7 5.43-5.28 5.71.42.36.8 1.08.8 2.18v3.1c0 .31.2.67.8.56A11.5 11.5 0 0 0 12 .5Z" />
                  </svg>
                </a>
                <a class="button button-secondary h-12 w-12 p-0" href={profile.links.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn" title="LinkedIn">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
                    <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 21h4V9H3v12Zm6.25-12H13v1.64h.05c.52-.99 1.8-2.04 3.7-2.04 3.96 0 4.69 2.6 4.69 5.98V21h-4v-5.7c0-1.36-.02-3.1-1.89-3.1-1.89 0-2.18 1.48-2.18 3V21h-4V9Z" />
                  </svg>
                </a>
              </div>
            </div>

            <img
              class="mx-auto aspect-[4/5] w-full max-w-[320px] rounded-[28px] border border-cyan-300/24 bg-slate-950 object-cover object-[50%_20%] shadow-2xl shadow-cyan-950/30 xl:max-w-[340px]"
              src={asset("images/nemanja-caricature.png")}
              alt={hero.imageAlt}
              width="1366"
              height="1536"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />

            <div class="max-w-none lg:col-span-2 xl:col-span-1 xl:ml-auto xl:max-w-sm">
              <p class="text-2xl font-bold leading-tight text-white sm:text-3xl lg:max-w-3xl xl:max-w-none">
                <span class="text-cyan-300">{availabilityLead}</span>{availabilityRest && ` ${availabilityRest}`}
              </p>
              <p class="mt-5 text-base leading-7 text-slate-300 lg:max-w-3xl xl:max-w-none">
                {profile.intro}
              </p>
              <p class="mt-4 text-sm leading-6 text-slate-400 lg:max-w-3xl xl:max-w-none">
                {profile.credibility}
              </p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3 border-t border-cyan-300/14 px-5 py-4 text-center text-sm font-black text-white sm:flex sm:flex-wrap sm:items-center sm:justify-center sm:gap-x-8 sm:gap-y-3 lg:flex-nowrap lg:justify-between lg:gap-x-5 lg:text-[0.82rem] xl:gap-x-8 xl:text-sm">
          {profile.proof.map((item: string) => <span class="tracking-normal text-slate-100">{item}</span>)}
        </div>
      </div>
    </div>
  </div>
</section>
