---
interface Props {
  title: string;
  problem: string;
  build: string;
  output: string;
  tags: string[];
}

const { title, problem, build, output, tags } = Astro.props;
---

<article class="card flex h-full flex-col p-5">
  <h3 class="text-xl font-bold text-white">{title}</h3>
  <div class="mt-4 grid flex-1 gap-3 text-sm leading-6 text-slate-300">
    <p><span class="font-semibold text-slate-100">Problem:</span> {problem}</p>
    <p><span class="font-semibold text-slate-100">What I build:</span> {build}</p>
    <p class="rounded-lg border border-cyan-400/16 bg-cyan-400/6 p-3">
      <span class="font-semibold text-cyan-100">Output:</span> {output}
    </p>
  </div>
  <div class="mt-5 flex flex-wrap gap-2">
    {tags.map((tag) => <span class="chip">{tag}</span>)}
  </div>
</article>
