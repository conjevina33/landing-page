---
interface Props {
  profile: any;
  contact: any;
}

const { profile, contact } = Astro.props;
---

<section id="contact" class="section">
  <div class="container">
    <div class="card overflow-hidden p-6 sm:p-8 lg:p-10">
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
        <div>
          <p class="eyebrow">{contact.eyebrow}</p>
          <h2 class="section-title">{contact.title}</h2>
          <p class="section-copy">
            {contact.copy}
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:min-w-64">
          <a class="button button-primary" href={profile.links.email}>{contact.email}</a>
          <a class="button button-secondary" href={profile.links.github} target="_blank" rel="noreferrer">{contact.github}</a>
          <a class="button button-secondary" href={profile.links.linkedin} target="_blank" rel="noreferrer">{contact.linkedin}</a>
          <a class="button button-secondary" href={profile.links.codepen} target="_blank" rel="noreferrer">{contact.codepen}</a>
        </div>
      </div>
    </div>
  </div>
</section>
